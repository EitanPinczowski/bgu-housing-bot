# Copy this file to ".env" and fill in your real values.
# .env is git-ignored — never commit it, never paste these into a chat.

# Gemini free-tier key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Telegram bot (from @BotFather) and your own chat id (from @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- optional: Google Sheets sink (see README "Google Sheets") ---
# Put the service-account JSON at auth/google_service_account.json and the
# sheet's id (the long id in its URL) here. Leave blank to keep it disabled.
# GOOGLE_SHEET_ID=

# --- local model via Ollama (set LLM_PROVIDER="openai_compatible" in config.py) ---
# Install Ollama, run `ollama pull gemma2:9b`, then uncomment these:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=gemma2:9b
# LLM_API_KEY=ollama
