# Copy this file to ".env" and fill in your real values.
# .env is git-ignored — never commit it, never paste these into a chat.

# Gemini free-tier key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Telegram bot (from @BotFather) and your own chat id (from @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- only if you switch to a local/Groq model (LLM_PROVIDER=openai_compatible) ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
# LLM_API_KEY=ollama
